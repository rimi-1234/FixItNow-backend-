NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/fixitnow?sslmode=require
0
FRONTEND_URL=http://localhost:5000

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
