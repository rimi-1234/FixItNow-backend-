JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

APP_URL=http://localhost:500
SSLCOMMERZ_STORE_PASSWD=your_store_password
SSLCOMMERZ_IS_LIVE=false
