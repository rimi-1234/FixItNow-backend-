{
  "info": {
    "name": "FixItNow API",
    "description": "Home-services marketplace API — Customer / Technician / Admin. Import into Postman. Set baseUrl and tokens after login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "adminToken", "value": "" },
    { "key": "techToken", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "serviceId", "value": "" },
    { "key": "technicianId", "value": "" },
    { "key": "paymentId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@fixitnow.com\",\n  \"password\": \"Admin@1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login Technician",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"technician@fixitnow.com\",\n  \"password\": \"tech123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@fixitnow.com\",\n  \"password\": \"customer123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newcustomer@example.com\",\n  \"password\": \"Pass@1234\",\n  \"role\": \"CUSTOMER\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Public Browse",
      "item": [
        {
          "name": "List Services",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/services"
          }
        },
        {
          "name": "List Technicians",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/technicians"
          }
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        }
      ]
    },
    {
      "name": "Customer",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"technicianId\": \"{{technicianId}}\",\n  \"serviceId\": \"{{serviceId}}\",\n  \"scheduledTime\": \"2026-08-15T10:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "My Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Create Stripe Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"provider\": \"STRIPE\"\n}"
            },
            "url": "{{baseUrl}}/payments/create"
          }
        },
        {
          "name": "Create SSLCommerz Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"provider\": \"SSLCOMMERZ\"\n}"
            },
            "url": "{{baseUrl}}/payments/create"
          }
        },
        {
          "name": "My Payments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/payments"
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/bookings/{{bookingId}}/cancel"
          }
        },
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"rating\": 5,\n  \"comment\": \"Great service\"\n}"
            },
            "url": "{{baseUrl}}/reviews"
          }
        }
      ]
    },
    {
      "name": "Technician",
      "item": [
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{techToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"skills\": [\"Plumbing\", \"Electrical\"],\n  \"experience\": 5,\n  \"hourlyRate\": 30,\n  \"location\": \"Dhaka\",\n  \"bio\": \"Experienced technician\"\n}"
            },
            "url": "{{baseUrl}}/technicians/profile"
          }
        },
        {
          "name": "Update Availability",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{techToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"availability\": [\"Monday 9AM-5PM\", \"Wednesday 10AM-4PM\"]\n}"
            },
            "url": "{{baseUrl}}/technicians/availability"
          }
        },
        {
          "name": "My Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{techToken}}" }],
            "url": "{{baseUrl}}/technicians/bookings"
          }
        },
        {
          "name": "Accept Booking",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{techToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACCEPTED\"\n}"
            },
            "url": "{{baseUrl}}/technicians/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Mark IN_PROGRESS",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{techToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
            },
            "url": "{{baseUrl}}/technicians/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Mark COMPLETED",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{techToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"COMPLETED\"\n}"
            },
            "url": "{{baseUrl}}/technicians/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Create Service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{techToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"AC Repair\",\n  \"description\": \"Split AC servicing\",\n  \"price\": 150,\n  \"categoryId\": \"PASTE_CATEGORY_ID\"\n}"
            },
            "url": "{{baseUrl}}/services"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Ban User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"BANNED\"\n}"
            },
            "url": "{{baseUrl}}/admin/users/PASTE_USER_ID"
          }
        },
        {
          "name": "List All Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/bookings"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"AC Repair\",\n  \"slug\": \"ac-repair\"\n}"
            },
            "url": "{{baseUrl}}/admin/categories"
          }
        }
      ]
    }
  ]
}
